{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Catique HUB",
  "version": "0.1.0",
  "identifier": "com.dzenlotus.catique-hub",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Catique HUB",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright © 2026 dzenlotus",
    "licenseFile": "../LICENSE",
    "category": "DeveloperTool",
    "shortDescription": "Catique HUB — AI agent orchestration",
    "longDescription": "Catique HUB is a desktop app for AI agent orchestration via kanban + prompt inheritance.",
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
