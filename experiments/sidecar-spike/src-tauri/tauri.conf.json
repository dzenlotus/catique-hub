{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sidecar-spike",
  "version": "0.0.1",
  "identifier": "com.dzenlotus.catique-hub.sidecar-spike",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "sidecar-spike",
        "width": 720,
        "height": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "resources": [
      "../sidecar/index.js"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "ctq-56 sidecar spike",
    "longDescription": "ADR-0002 spike: validates Tauri 2.x can spawn a Node sidecar over stdio JSON-RPC.",
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
